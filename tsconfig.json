{
  "compilerOptions": {
    "target": "es2017",
    "lib": ["dom", "es2021"],
    "module": "esnext",
    "moduleResolution": "node",
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist"
  },
  "include": ["extension/src/**/*", "__tests__/**/*", "e2e/**/*"],
  "exclude": ["node_modules"]
}
